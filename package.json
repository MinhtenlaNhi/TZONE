{
  "name": "online-course-platform",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for online course platform (React + Node.js + Express).",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "prestart": "node scripts/ensure-client-build.cjs",
    "build": "npm run build -w client",
    "start": "npm start -w server",
    "dev": "concurrently \"npm run dev -w client\" \"npm run dev -w server\"",
    "client:dev": "npm run dev -w client",
    "server:dev": "npm run dev -w server"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
