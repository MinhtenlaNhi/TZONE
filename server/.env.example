PORT=5000
# Email quản trị (phân tách bằng dấu phẩy): cập nhật link buổi học + gọi API /api/admin/* (phê duyệt giáo viên)
# ADMIN_EMAILS=you@example.com
# Bí mật API quản trị (ô mật khẩu trên /admin khi không dùng mật khẩu EmailRegistration). Mặc định trong code: Quangpham@123 — nên đổi bằng env khi deploy.
# ADMIN_API_SECRET=chuỗi_bí_mật_của_bạn
# Atlas: thay USER, PASSWORD (mã hóa URL: @ → %40), cluster và tên DB. Không dùng mật khẩu thật trong file .example — chỉ copy sang server/.env (local) hoặc Render Environment.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/online_course_platform?retryWrites=true&w=majority
JWT_SECRET=replace_with_long_random_string
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=your_folder_name